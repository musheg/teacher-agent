# =====================================================================
# Teacher Agents – environment variables
# Copy this file to vars/.env and fill in real values.
# =====================================================================

# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development                  # development | staging | production
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                      # json | console
SERVICE_NAME=teacher-agents-api

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# Optional admin bootstrap (created on first startup if both are set)
CREATE_ADMIN_EMAIL=
CREATE_ADMIN_PASSWORD=

# ── Data stores ──────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://teacher:teacher@postgres:5432/teacher
REDIS_URL=redis://redis:6379/0
CONTEXT_MAX_TURNS=20
CONTEXT_SUMMARY_THRESHOLD_TOKENS=4000

# ── Google STT (Chirp_2 supports hy-AM) ──────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
STT_LANGUAGE=hy-AM
STT_MODEL=chirp_2
STT_LOCATION=asia-southeast1
STT_PROJECT_ID=

# ── TTS (pluggable; default openai, always streaming) ────────────────
TTS_PROVIDER=openai                  # openai | azure | elevenlabs | google
TTS_VOICE=alloy
OPENAI_TTS_MODEL=gpt-4o-mini-tts
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_TTS_VOICE=hy-AM-AnahitNeural
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── LLM provider keys ────────────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ── Per-agent models (comma-separated = primary,fallback1,fallback2) ─
TUTOR_MODEL=openai:gpt-5.4,google-gla:gemini-2.5-pro,anthropic:claude-4.6-sonnet
SOLVER_MODEL=openai:gpt-5.4-mini,openai:gpt-5.4
CURRICULUM_MODEL=openai:gpt-5.4-mini
ASSESSMENT_MODEL=openai:gpt-5.4-mini
VISUALIZATION_MODEL=openai:gpt-5.4-mini
TRANSLATOR_PROSE_MODEL=openai:gpt-4o-mini,google-gla:gemini-2.5-flash
TRANSLATOR_MATH_MODEL=openai:gpt-5.4-mini
SPEECH_MODEL=openai:gpt-4o-mini
SAFETY_MODEL=openai:gpt-4o-mini
SUMMARIZER_MODEL=openai:gpt-4o-mini
MODERATION_MODEL=omni-moderation-latest

# ── Limits & feature flags ───────────────────────────────────────────
MAX_AUDIO_SECONDS=30
MAX_TURNS_PER_SESSION=200
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
FEATURE_OFFLINE_FALLBACK=true

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
